# CryptoPortfolioManager environment variables
# Rename this file to .env and fill in your credentials.

# CoinGecko API key (if required; some endpoints may work without key)
CG_API_KEY=your_coin_gecko_api_key

# Email settings (used by email_alert.py for risk notifications)
EMAIL_SENDER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_RECEIVER=recipient_email@example.com
